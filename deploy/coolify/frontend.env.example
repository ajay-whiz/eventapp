# Coolify -> Frontend application environment variables
# Base directory in Coolify: FRONTEND
# Build pack: Dockerfile
# Port: 5173
# Health check path: /health

NODE_ENV=production
PORT=5173

# Runtime API proxy target (server.js forwards /api/* here)
# Use your backend public URL without /api/v1
API_BASE_URL=https://api.yourdomain.com

# Build-time variables (set as Coolify "Build Arguments" or build-time env)
VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_IMAGE_BASE_URL=https://api.yourdomain.com/uploads/profile/
