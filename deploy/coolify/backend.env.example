# Coolify -> Backend application environment variables
# Base directory in Coolify: BACKEND
# Build pack: Dockerfile
# Port: 3000
# Health check path: /api/v1/health

NODE_ENV=production
PORT=3000

# Required
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/event_booking?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=2d
JWT_ISSUER=https://api.yourdomain.com
FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com,http://localhost:5173

# Auth
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Email (choose one provider)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# File storage (optional)
AWS_REGION=us-east-1
AWS_BUCKET_NAME=
AWS_BUCKET_FOLDER=uploads
AWS_BUCKET_TEMP_FOLDER=temp-documents
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Supabase storage (optional alternative to AWS)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_STORAGE_BUCKET=uploads

# PDF generation (set automatically by Dockerfile)
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
